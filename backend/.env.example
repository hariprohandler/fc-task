# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/fc_task

# --- Airtable OAuth (create an integration at https://airtable.com/create/oauth ) ---
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=
# Must match the redirect URL configured on the integration (e.g. http://localhost:3000/api/airtable/oauth/callback)
AIRTABLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/airtable/oauth/callback
# Space-separated scopes (must be enabled on the integration)
AIRTABLE_OAUTH_SCOPES=schema.bases:read data.records:read
AIRTABLE_OAUTH_SUCCESS_REDIRECT=http://localhost:4200

# API host (override only if Airtable changes)
AIRTABLE_WEB_HOST=https://airtable.com
AIRTABLE_API_BASE=https://api.airtable.com/v0

# --- Part B: Web session + revision history (browser cookies) ---
# Optional: used by POST /api/airtable/web-session/login/begin if not sent in the body
AIRTABLE_WEB_LOGIN_EMAIL=
AIRTABLE_WEB_LOGIN_PASSWORD=
# Path template for revision HTML (confirm in browser Network tab; placeholders: {baseId} {tableId} {rowId})
AIRTABLE_REVISION_HISTORY_PATH_TEMPLATE=/v0.3/application/{baseId}/readRowActivitiesAndComments
# JSON body template after placeholder substitution (must stay valid JSON)
AIRTABLE_REVISION_POST_BODY_TEMPLATE={"tableId":"{tableId}","rowId":"{rowId}"}
# Optional: override Cheerio selectors as JSON (entry, fieldLabel, oldValue, newValue, uuid, createdTime, user)
# AIRTABLE_REVISION_HTML_SELECTORS=
