# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/fc_task

# GitHub: Raw Data lists GitHub when GITHUB_TOKEN / GH_TOKEN / GITHUB_ACCESS_TOKEN is set, a github_* collection exists, or GITHUB_INTEGRATION_ACTIVE=1
# GITHUB_TOKEN=

# --- Airtable OAuth ---
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=
AIRTABLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/airtable/oauth/callback
AIRTABLE_OAUTH_SCOPES=schema.bases:read data.records:read
AIRTABLE_OAUTH_SUCCESS_REDIRECT=http://localhost:4200

AIRTABLE_WEB_HOST=https://airtable.com
AIRTABLE_API_BASE=https://api.airtable.com/v0

# --- Web session: paste Cookie via POST /api/airtable/web-session/cookies (HTTP shape: src/airtable/airtable-revision-http.constants.ts) ---
# Optional: AIRTABLE_VENDOR_LOG=0 to disable structured vendor logs; AIRTABLE_REVISION_DEBUG=1 for larger revision body previews
